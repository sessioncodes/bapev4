# Vercel Postgres (auto-set when you link a Postgres store in Vercel dashboard)
POSTGRES_URL=postgres://...
POSTGRES_PRISMA_URL=postgres://...
POSTGRES_URL_NON_POOLING=postgres://...
POSTGRES_USER=...
POSTGRES_HOST=...
POSTGRES_PASSWORD=...
POSTGRES_DATABASE=...

# Admin secret (same value in bot .env and panel .env)
ADMIN_SECRET=your-secret-key-here
